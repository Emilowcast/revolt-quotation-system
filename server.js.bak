// server.js - Demo completo: plantillas + API CRUD (Prisma)
require('dotenv').config();
const express = require('express');
const fs = require('fs');
const path = require('path');
const bodyParser = require('body-parser');
const multer = require('multer');
const { PDFDocument, StandardFonts, rgb } = require('pdf-lib');
const { PrismaClient } = require('@prisma/client');
const crypto = require('crypto');

const app = express();
const prisma = new PrismaClient();

app.use(bodyParser.json({ limit: '30mb' }));
app.use(bodyParser.urlencoded({ extended: true, limit: '30mb' }));

const PORT = process.env.PORT || 3000;
const TEMPLATES_DIR = path.join(__dirname, 'templates');
const CALIB_DIR = path.join(TEMPLATES_DIR, 'calibrations');
if (!fs.existsSync(TEMPLATES_DIR)) fs.mkdirSync(TEMPLATES_DIR, { recursive: true });
if (!fs.existsSync(CALIB_DIR)) fs.mkdirSync(CALIB_DIR, { recursive: true });

// Multer: guarda archivos en /templates
const storage = multer.diskStorage({
  destination: (req, file, cb) => cb(null, TEMPLATES_DIR),
  filename: (req, file, cb) => cb(null, path.basename(file.originalname))
});
const upload = multer({ storage });

function safeName(n) { return path.basename(String(n || '')).replace(/\s+/g, '_'); }

// -------------------- Template endpoints (mantener compatibilidad) --------------------
app.get('/api/templates', async (req, res) => {
  try {
    const files = fs.readdirSync(TEMPLATES_DIR)
      .filter(f => !fs.lstatSync(path.join(TEMPLATES_DIR, f)).isDirectory())
      .filter(f => /\.(pdf|png|jpg|jpeg)$/i.test(f))
      .map(f => ({ name: f }));
    // check DB templates
    const dbTemplates = await prisma.template.findMany({ include: { versions: true } });
    const map = {};
    files.forEach(f => map[f.name] = { name: f.name, calibrated: false });
    dbTemplates.forEach(t => {
      t.versions.forEach(v => {
        if (map[v.filename]) map[v.filename].calibrated = map[v.filename].calibrated || !!v.calibration;
      });
    });
    const merged = Object.values(map);
    res.json({ ok: true, templates: merged });
  } catch (e) {
    console.error(e);
    res.status(500).json({ ok: false, error: e.message });
  }
});

app.post('/api/templates/upload', upload.single('template'), async (req, res) => {
  try {
    if (!req.file) return res.status(400).json({ ok: false, error: 'No file' });
    const filename = safeName(req.file.filename);
    const storagePath = path.join('/templates', filename);
    // create template record if not exists
    let tpl = await prisma.template.findUnique({ where: { name: filename } });
    if (!tpl) {
      tpl = await prisma.template.create({ data: { name: filename } });
    }
    // create version
    await prisma.templateVersion.create({
      data: {
        templateId: tpl.id,
        filename,
        storagePath,
        calibration: {}
      }
    });
    res.json({ ok: true, filename, path: `/templates/${filename}` });
  } catch (e) {
    console.error(e);
    res.status(500).json({ ok: false, error: e.message });
  }
});

app.get('/api/templates/:name/calibration', async (req, res) => {
  try {
    const name = safeName(req.params.name);
    const ver = await prisma.templateVersion.findFirst({
      where: { filename: name },
      orderBy: { createdAt: 'desc' }
    });
    if (!ver || !ver.calibration) return res.status(404).json({ ok: false, error: 'No calibration' });
    res.json({ ok: true, calibration: ver.calibration });
  } catch (e) {
    console.error(e);
    res.status(500).json({ ok:false, error: e.message });
  }
});

app.post('/save-calibration', async (req, res) => {
  try {
    const payload = req.body || {};
    const templateName = safeName(req.query.template || payload.template || payload.templateName);
    if (!templateName) return res.status(400).json({ ok: false, error: 'Falta nombre de plantilla (query ?template=...)' });
    // normalize numbers
    payload.fields = payload.fields || {};
    for (const k of Object.keys(payload.fields)) {
      const f = payload.fields[k];
      f.x = Number(f.x);
      f.y = Number(f.y);
      f.anchor = (typeof f.anchor === 'string') ? f.anchor : 'left';
      f.vAnchor = (typeof f.vAnchor === 'string') ? f.vAnchor : 'baseline';
      f.fontSize = Number(f.fontSize) || 10;
      f.offsetX = (f.offsetX === undefined) ? 0 : Number(f.offsetX);
      f.offsetY = (f.offsetY === undefined) ? 0 : Number(f.offsetY);
    }
    payload.table = payload.table || { startY: 0.61, lineHeight: 0.045 };
    payload.table.startY = Number(payload.table.startY) || 0.61;
    payload.table.lineHeight = Number(payload.table.lineHeight) || 0.045;

    // find version (or create)
    let ver = await prisma.templateVersion.findFirst({ where: { filename: templateName }, orderBy: { createdAt: 'desc' } });
    if (!ver) {
      // ensure template exists
      let tpl = await prisma.template.findUnique({ where: { name: templateName } });
      if (!tpl) tpl = await prisma.template.create({ data: { name: templateName } });
      ver = await prisma.templateVersion.create({
        data: { templateId: tpl.id, filename: templateName, storagePath: path.join('/templates', templateName), calibration: payload }
      });
    } else {
      ver = await prisma.templateVersion.update({
        where: { id: ver.id },
        data: { calibration: payload }
      });
    }
    // also save a disk copy for compatibility
    try { fs.writeFileSync(path.join(CALIB_DIR, templateName + '.json'), JSON.stringify(payload, null, 2), 'utf8'); } catch(e){console.warn('fs save fail', e.message);}
    res.json({ ok:true, saved: true });
  } catch (e) {
    console.error(e);
    res.status(500).json({ ok:false, error: e.message });
  }
});

// -------------------- PDF generation (reuse previous logic) --------------------
async function generatePdfBuffer(templateFilename, data = {}, options = {}) {
  const safe = safeName(templateFilename);
  const templatePath = path.join(TEMPLATES_DIR, safe);
  if (!fs.existsSync(templatePath)) throw new Error('Plantilla no encontrada: ' + safe);

  const existingPdfBytes = fs.readFileSync(templatePath);
  const pdfDoc = await PDFDocument.load(existingPdfBytes);
  const pages = pdfDoc.getPages();
  const page = pages[0];
  const { width, height } = page.getSize();
  const font = await pdfDoc.embedFont(StandardFonts.Helvetica);

  // load calibration (from DB or file fallback)
  let calib = null;
  try {
    const ver = await prisma.templateVersion.findFirst({ where: { filename: safe }, orderBy: { createdAt: 'desc' } });
    if (ver && ver.calibration) calib = ver.calibration;
  } catch (e) { calib = null; }
  if (!calib) {
    const fp = path.join(CALIB_DIR, safe + '.json');
    if (fs.existsSync(fp)) {
      try { calib = JSON.parse(fs.readFileSync(fp,'utf8')); } catch(e){ calib = null; }
    }
  }

  function drawTextWithAnchor(text, coord, optionsLocal = {}) {
    if (!coord || typeof coord.x !== 'number' || typeof coord.y !== 'number') return;
    const anchor = coord.anchor || 'left';
    const vAnchor = coord.vAnchor || 'baseline';
    const fontSize = Number(coord.fontSize) || 10;
    const xPercWithOffset = coord.x + (coord.offsetX || 0);
    const yPercWithOffset = coord.y + (coord.offsetY || 0);
    const xPts = width * xPercWithOffset;
    const yPts = height * yPercWithOffset;

    const textStr = (text === undefined || text === null) ? '' : String(text);
    let textWidth = 0;
    try { textWidth = font.widthOfTextAtSize(textStr, fontSize); } catch (e) { textWidth = 0; }

    let xDraw;
    if (anchor === 'center') xDraw = Math.round(xPts - (textWidth / 2));
    else if (anchor === 'right') xDraw = Math.round(xPts - textWidth);
    else xDraw = Math.round(xPts);

    let yDraw;
    if (vAnchor === 'top') {
      yDraw = Math.round(yPts - fontSize * 0.8);
    } else if (vAnchor === 'baseline') {
      yDraw = Math.round(yPts);
    } else if (vAnchor === 'center') {
      yDraw = Math.round(yPts - (fontSize * 0.35));
    } else {
      yDraw = Math.round(yPts);
    }

    if (xDraw < 0) xDraw = 0;
    if (yDraw < 0) yDraw = 0;

    page.drawText(textStr, { x: xDraw, y: yDraw, size: fontSize, font });

    if (optionsLocal.debug) {
      const rawX = width * coord.x;
      const rawY = height * coord.y;
      page.drawRectangle({ x: Math.round(rawX - 3), y: Math.round(rawY - 3), width: 6, height: 6, color: rgb(1, 0, 0) });
      page.drawRectangle({ x: Math.round(xPts - 3), y: Math.round(yPts - 3), width: 6, height: 6, color: rgb(0, 0, 1) });
      if (optionsLocal.label) {
        const lblSize = Math.max(6, Math.min(8, fontSize * 0.7));
        try { page.drawText(optionsLocal.label, { x: Math.round(rawX + 6), y: Math.round(rawY - 3), size: lblSize, font }); } catch(e){}
      }
    }
  }

  // parse items
  let items = [];
  if (data.items) {
    try { items = typeof data.items === 'string' ? JSON.parse(data.items) : data.items; } catch (e) { items = []; }
  }
  if (!Array.isArray(items) || items.length === 0) {
    items = [{ modelo: 'RM-042-220', descripcion: 'REGULADOR 4 kVA', precio: '987.36', cant: '1', subtotal: '987.36' }];
  }

  // draw non-item fields
  const drawn = new Set();
  if (calib && calib.fields) {
    for (const fname of Object.keys(calib.fields)) {
      if (fname.startsWith('item_')) continue;
      const coord = calib.fields[fname];
      const value = (data && (data[fname] !== undefined)) ? data[fname] : (coord.sampleValue || '');
      drawTextWithAnchor(value, coord, { debug: options.debug, label: fname });
      drawn.add(fname);
    }
  }

  // fallback defaults
  const defaults = {
    folio: { x: 0.72, y: 0.88, anchor: 'left', vAnchor: 'baseline', fontSize: 10 },
    fecha: { x: 0.83, y: 0.88, anchor: 'left', vAnchor: 'baseline', fontSize: 10 },
    cliente: { x: 0.08, y: 0.80, anchor: 'left', vAnchor: 'baseline', fontSize: 12 },
    subtotal: { x: 0.88, y: 0.36, anchor: 'right', vAnchor: 'baseline', fontSize: 10 },
    descuento: { x: 0.88, y: 0.33, anchor: 'right', vAnchor: 'baseline', fontSize: 10 },
    impuestos: { x: 0.88, y: 0.30, anchor: 'right', vAnchor: 'baseline', fontSize: 10 },
    total: { x: 0.88, y: 0.27, anchor: 'right', vAnchor: 'baseline', fontSize: 12 },
  };
  for (const k of Object.keys(defaults)) {
    if (drawn.has(k)) continue;
    const def = defaults[k];
    const val = (data && (data[k] !== undefined)) ? data[k] : '';
    drawTextWithAnchor(val, def, { debug: options.debug, label: k });
    drawn.add(k);
  }

  // item columns - reading from calib if exists
  let modeloX = 0.05, descripcionX = 0.28, precioX = 0.68, cantX = 0.78, subtotalX = 0.88;
  let tableStartY = 0.61, lineHeight = 0.045;
  if (calib) {
    if (calib.fields && calib.fields['item_modelo']) modeloX = Number(calib.fields['item_modelo'].x);
    if (calib.fields && calib.fields['item_descripcion']) descripcionX = Number(calib.fields['item_descripcion'].x);
    if (calib.fields && calib.fields['item_precio']) precioX = Number(calib.fields['item_precio'].x);
    if (calib.fields && calib.fields['item_cant']) cantX = Number(calib.fields['item_cant'].x);
    if (calib.fields && calib.fields['item_subtotal']) subtotalX = Number(calib.fields['item_subtotal'].x);
    if (calib.table) {
      tableStartY = Number(calib.table.startY) || tableStartY;
      lineHeight = Number(calib.table.lineHeight) || lineHeight;
    }
  }

  for (let i = 0; i < items.length; i++) {
    const yPerc = tableStartY - i * lineHeight;
    if (yPerc <= 0) continue;
    const baseCoordModelo = { x: modeloX, y: yPerc, anchor: 'left', vAnchor: 'baseline', fontSize: 9, offsetX: (calib && calib.fields && calib.fields['item_modelo'] ? (calib.fields['item_modelo'].offsetX||0) : 0), offsetY: (calib && calib.fields && calib.fields['item_modelo'] ? (calib.fields['item_modelo'].offsetY||0) : 0) };
    const baseCoordDesc = { x: descripcionX, y: yPerc, anchor: 'left', vAnchor: 'baseline', fontSize: 9, offsetX: (calib && calib.fields && calib.fields['item_descripcion'] ? (calib.fields['item_descripcion'].offsetX||0) : 0), offsetY: (calib && calib.fields && calib.fields['item_descripcion'] ? (calib.fields['item_descripcion'].offsetY||0) : 0) };
    const baseCoordPrecio = { x: precioX, y: yPerc, anchor: 'right', vAnchor: 'baseline', fontSize: 9, offsetX: (calib && calib.fields && calib.fields['item_precio'] ? (calib.fields['item_precio'].offsetX||0) : 0), offsetY: (calib && calib.fields && calib.fields['item_precio'] ? (calib.fields['item_precio'].offsetY||0) : 0) };
    const baseCoordCant = { x: cantX, y: yPerc, anchor: 'left', vAnchor: 'baseline', fontSize: 9, offsetX: (calib && calib.fields && calib.fields['item_cant'] ? (calib.fields['item_cant'].offsetX||0) : 0), offsetY: (calib && calib.fields && calib.fields['item_cant'] ? (calib.fields['item_cant'].offsetY||0) : 0) };
    const baseCoordSubtotal = { x: subtotalX, y: yPerc, anchor: 'right', vAnchor: 'baseline', fontSize: 9, offsetX: (calib && calib.fields && calib.fields['item_subtotal'] ? (calib.fields['item_subtotal'].offsetX||0) : 0), offsetY: (calib && calib.fields && calib.fields['item_subtotal'] ? (calib.fields['item_subtotal'].offsetY||0) : 0) };
    drawTextWithAnchor(items[i].modelo || '', baseCoordModelo, { debug: options.debug, label: 'item_modelo' });
    drawTextWithAnchor(items[i].descripcion || '', baseCoordDesc, { debug: options.debug, label: 'item_descripcion' });
    drawTextWithAnchor(items[i].precio !== undefined ? String(items[i].precio) : '', baseCoordPrecio, { debug: options.debug, label: 'item_precio' });
    drawTextWithAnchor(items[i].cant || '1', baseCoordCant, { debug: options.debug, label: 'item_cant' });
    drawTextWithAnchor(items[i].subtotal !== undefined ? String(items[i].subtotal) : '', baseCoordSubtotal, { debug: options.debug, label: 'item_subtotal' });
  }

  const pdfBytes = await pdfDoc.save();
  return pdfBytes;
}

app.post('/preview', async (req, res) => {
  try {
    const templateName = safeName(req.body.template);
    if (!templateName) return res.status(400).send('Falta template en body (template)');
    const pdfBuf = await generatePdfBuffer(templateName, req.body, { debug: Boolean(req.body.debug) });
    res.setHeader('Content-Type', 'application/pdf');
    res.setHeader('Content-Disposition', 'inline; filename=preview.pdf');
    res.send(Buffer.from(pdfBuf));
  } catch (e) {
    console.error('Error en /preview', e);
    res.status(500).send('Error generando preview: ' + e.message);
  }
});

app.post('/generate', async (req, res) => {
  try {
    const templateName = safeName(req.body.template);
    if (!templateName) return res.status(400).send('Falta template en body (template)');
    const pdfBuf = await generatePdfBuffer(templateName, req.body, { debug: Boolean(req.body.debug) });
    res.setHeader('Content-Type', 'application/pdf');
    res.setHeader('Content-Disposition', 'attachment; filename=cotizacion_generada.pdf');
    res.send(Buffer.from(pdfBuf));
  } catch (e) {
    console.error('Error en /generate', e);
    res.status(500).send('Error generando PDF: ' + e.message);
  }
});

// -------------------- API: Clients --------------------
app.get('/api/clients', async (req, res) => {
  try {
    const all = await prisma.client.findMany({ orderBy: { createdAt: 'desc' } });
    res.json({ ok:true, clients: all });
  } catch (e) { console.error(e); res.status(500).json({ ok:false, error: e.message }); }
});

app.get('/api/clients/:id', async (req, res) => {
  try {
    const id = Number(req.params.id);
    const c = await prisma.client.findUnique({ where: { id } });
    if (!c) return res.status(404).json({ ok:false, error:'Not found' });
    res.json({ ok:true, client: c });
  } catch (e) { console.error(e); res.status(500).json({ ok:false, error: e.message }); }
});

app.post('/api/clients', async (req, res) => {
  try {
    const body = req.body;
    const c = await prisma.client.create({ data: {
      name: body.name || 'Sin nombre',
      company: body.company || null,
      phone: body.phone || null,
      email: body.email || null,
      address: body.address || null,
      notes: body.notes || null
    }});
    res.json({ ok:true, client: c });
  } catch (e) { console.error(e); res.status(500).json({ ok:false, error: e.message }); }
});

app.put('/api/clients/:id', async (req, res) => {
  try {
    const id = Number(req.params.id);
    const body = req.body;
    const c = await prisma.client.update({ where: { id }, data: {
      name: body.name, company: body.company, phone: body.phone, email: body.email, address: body.address, notes: body.notes
    }});
    res.json({ ok:true, client: c });
  } catch (e) { console.error(e); res.status(500).json({ ok:false, error: e.message }); }
});

app.delete('/api/clients/:id', async (req, res) => {
  try {
    const id = Number(req.params.id);
    await prisma.client.delete({ where: { id }});
    res.json({ ok:true });
  } catch (e) { console.error(e); res.status(500).json({ ok:false, error: e.message }); }
});

