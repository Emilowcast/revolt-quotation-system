app.post('/api/products', async (req, res) => {
  try {
    const b = req.body;
    const p = await prisma.product.create({ data: {
      model: b.model,
      description: b.description || null,
      price: Number(b.price) || 0,
      currency: b.currency || 'USD',
      ficha: b.ficha || null
    }});
    res.json({ ok:true, product: p });
  } catch (e) { console.error(e); res.status(500).json({ ok:false, error: e.message }); }
});

// -------------------- API: Quotes --------------------
// Create quote with items (atomic)
app.post('/api/quotes', async (req, res) => {
  try {
    const b = req.body;
    // expected: folio, clientId (optional), items: [{modelo, descripcion, unitPrice, qty, subtotal, productId?}], discount, tax, currency
    const items = Array.isArray(b.items) ? b.items : [];
    const subtotal = Number(b.subtotal) || items.reduce((s,it) => s + (Number(it.subtotal)||0), 0);
    const discount = Number(b.discount) || 0;
    const tax = Number(b.tax) || 0;
    const total = Number(b.total) || Math.max(0, subtotal - discount) + tax;

    const quote = await prisma.quote.create({
      data: {
        folio: b.folio || `F-${Date.now()}`,
        clientId: b.clientId || null,
        subtotal,
        discount,
        tax,
        total,
        currency: b.currency || 'USD',
        status: b.status || 'vigente',
        notes: b.notes || null,
        items: {
          create: items.map(it => ({
            modelo: it.modelo || (it.productId ? undefined : 'N/E'),
            descripcion: it.descripcion || null,
            unitPrice: Number(it.unitPrice) || Number(it.precio) || 0,
            qty: Number(it.qty) || Number(it.cant) || 1,
            subtotal: Number(it.subtotal) || ((Number(it.unitPrice)||0) * (Number(it.qty)||1)),
            productId: it.productId || null
          }))
        }
      },
      include: { items: true }
    });

    res.json({ ok:true, quote });
  } catch (e) { console.error(e); res.status(500).json({ ok:false, error: e.message }); }
});

app.get('/api/quotes', async (req, res) => {
  try {
    const qs = await prisma.quote.findMany({ orderBy: { createdAt: 'desc' }, include: { items: true, client: true } });
    res.json({ ok:true, quotes: qs });
  } catch (e) { console.error(e); res.status(500).json({ ok:false, error: e.message }); }
});

app.get('/api/quotes/:id', async (req, res) => {
  try {
    const id = Number(req.params.id);
    const q = await prisma.quote.findUnique({ where: { id }, include: { items: true, client: true } });
    if (!q) return res.status(404).json({ ok:false, error:'Not found' });
    res.json({ ok:true, quote: q });
  } catch (e) { console.error(e); res.status(500).json({ ok:false, error: e.message }); }
});

app.delete('/api/quotes/:id', async (req, res) => {
  try {
    const id = Number(req.params.id);
    // soft-delete strategy could be implemented; for now we delete
    await prisma.quote.delete({ where: { id }});
    res.json({ ok:true });
  } catch (e) { console.error(e); res.status(500).json({ ok:false, error: e.message }); }
});

// -------------------- Static + start --------------------
app.use(express.static(path.join(__dirname, 'public')));
app.use('/templates', express.static(TEMPLATES_DIR));

app.listen(PORT, () => {
  console.log(`Server corriendo en http://localhost:${PORT}`);
});
