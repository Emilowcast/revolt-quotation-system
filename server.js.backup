    });
    
    worksheet.addRow({
      model: 'BSN-4KVA-2F-220V',
      description: 'Regulador básico 4kVA 2Φ 220V',
      price: 4500.00,
      currency: 'USD',
      ficha: 'bsn_4kva.pdf'
    });
    
    worksheet.addRow({
      model: 'UPS-1000VA',
      description: 'UPS 1000VA',
      price: 450.00,
      currency: 'USD',
      ficha: ''
    });
    
    // Aplicar formato de moneda
    worksheet.getColumn('price').numFmt = '"$"#,##0.00';
    
